---
import "../styles/global.css";

import "@fontsource/metropolis/800.css";
import "@fontsource/metropolis/700.css";

import "@fontsource/metropolis/400.css";
import PostHog from "../components/posthog.astro";

import MetaPixel from "../components/MetaPixel.astro";
import GoogleAds from "../components/GoogleAds.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <GoogleAds />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Método para aumentar a produção de leite materno"
    />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>LactoFlow®</title>

    <PostHog />

    <MetaPixel />

    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "r95xzttid8");
    </script>
  </head>
  <body class="bg-blue">
    <slot />

    <!-- Server-side PageView event (fires once per page render) -->
    <script is:inline>
      (function () {
        if (window.__serverPageViewSent) return;
        window.__serverPageViewSent = true;

        function getCookie(name) {
          var match = document.cookie.match(new RegExp("(^|; )" + name + "=([^;]*)"));
          return match ? decodeURIComponent(match[2]) : null;
        }

        fetch("/api/track", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            event: "PageView",
            url: window.location.href,
            event_id: getCookie("event_id"),
            fbc: getCookie("_fbc"),
            fbp: getCookie("_fbp"),
          }),
          keepalive: true,
        }).catch(function (err) {
          console.error("[Track] PageView error:", err);
        });
      })();
    </script>
  </body>
</html>
